  "version": "0.1.0",
  "description": "Sync Plaud AI voice recordings to Obsidian as formatted markdown notes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "plaud-for-claude": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
